  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "demo": "tsx src/index.ts demo",
    "intake": "tsx src/index.ts intake",
    "sync": "tsx src/index.ts sync",
    "updates": "tsx src/index.ts updates",
    "prep": "tsx src/index.ts prep",
    "courses": "tsx src/index.ts courses",
    "tasks": "tsx src/index.ts tasks",
    "task": "tsx src/index.ts task",
    "canvas:profile": "tsx src/index.ts canvas profile",
    "canvas:preview": "tsx src/index.ts canvas preview",
    "canvas:sync": "tsx src/index.ts canvas sync",
    "state": "tsx src/index.ts state",
    "test": "tsx --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
