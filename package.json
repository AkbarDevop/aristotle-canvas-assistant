{
  "name": "aristotle-canvas-assistant",
  "version": "0.1.0",
  "type": "module",
  "description": "Terminal-first Canvas copilot for assignment triage, study planning, and exam prep.",
  "license": "MIT",
  "author": "Akbar",
  "homepage": "https://github.com/AkbarDevop/aristotle-canvas-assistant#readme",
  "bugs": {
    "url": "https://github.com/AkbarDevop/aristotle-canvas-assistant/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkbarDevop/aristotle-canvas-assistant.git"
  },
  "keywords": [
    "canvas",
    "canvas-lms",
    "terminal",
    "cli",
    "student-productivity",
    "codex",
    "claude-code",
